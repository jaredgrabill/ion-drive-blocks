{
  "$schema": "https://ion-drive.dev/schema/block.json",
  "name": "crm",
  "version": "0.2.0",
  "title": "CRM",
  "description": "Leads, companies, contacts, deals, and activities — lead capture, conversion, and a stage-tracked sales pipeline.",
  "author": "Ion Shift Labs <hello@ionshiftlabs.com>",
  "categories": [
    "sales",
    "crm"
  ],
  "meta": {
    "icon": "🪐",
    "docs": "https://ion-drive.dev/blocks/crm",
    "secrets": {
      "crm_inbound_token": "Shared token the inbound_lead hook requires in its x-crm-token header."
    }
  },
  "requires": {
    "handlers": [
      "persist_event"
    ],
    "plugins": []
  },
  "actions": [
    {
      "name": "convert_lead",
      "description": "Convert a lead into a company + contact (de-duplicated) and optionally a deal, then mark the lead converted.",
      "rbac": {
        "resource": "leads",
        "action": "update"
      },
      "input": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string",
            "format": "uuid",
            "description": "The lead to convert"
          },
          "create_deal": {
            "type": "boolean",
            "default": false,
            "description": "Also open a deal for the new company/contact"
          },
          "deal_title": {
            "type": "string",
            "description": "Title for the created deal (defaults to \"<company> — new deal\")"
          },
          "amount": {
            "type": "number",
            "minimum": 0,
            "description": "Deal amount"
          }
        },
        "required": ["lead_id"]
      }
    },
    {
      "name": "set_deal_stage",
      "description": "Move a deal through the pipeline: applies the stage's default probability, stamps closed_at / lost_reason on close, and logs a note activity.",
      "rbac": {
        "resource": "deals",
        "action": "update"
      },
      "input": {
        "type": "object",
        "properties": {
          "deal_id": {
            "type": "string",
            "format": "uuid"
          },
          "stage": {
            "type": "string",
            "enum": ["prospecting", "qualification", "proposal", "negotiation", "closed_won", "closed_lost"]
          },
          "lost_reason": {
            "type": "string",
            "enum": ["price", "competitor", "timing", "no_budget", "unresponsive", "other"],
            "description": "Required context when moving to closed_lost (defaults to \"other\")"
          }
        },
        "required": ["deal_id", "stage"]
      }
    },
    {
      "name": "log_activity",
      "description": "Log a call/email/meeting/task/note against a contact, company, and/or deal, stamping last_activity_at on the linked contact and deal.",
      "rbac": {
        "resource": "activities",
        "action": "create"
      },
      "input": {
        "type": "object",
        "properties": {
          "subject": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["call", "email", "meeting", "task", "note"],
            "default": "note"
          },
          "direction": {
            "type": "string",
            "enum": ["inbound", "outbound"]
          },
          "notes": { "type": "string" },
          "contact_id": { "type": "string", "format": "uuid" },
          "company_id": { "type": "string", "format": "uuid" },
          "deal_id": { "type": "string", "format": "uuid" },
          "due_date": { "type": "string", "format": "date-time" },
          "completed": { "type": "boolean" },
          "duration_minutes": { "type": "integer", "minimum": 0 }
        },
        "required": ["subject"]
      }
    }
  ],
  "hooks": [
    {
      "name": "inbound_lead",
      "description": "Web-to-lead capture endpoint — POST a form payload with the shared x-crm-token header to create a lead (de-duplicated by email)."
    }
  ],
  "objects": [
    {
      "name": "leads",
      "displayName": "Leads",
      "description": "Unqualified inbound interest — captured, worked, then converted into a company/contact/deal or disqualified.",
      "fields": [
        {
          "name": "first_name",
          "displayName": "First Name",
          "columnType": "short_text"
        },
        {
          "name": "last_name",
          "displayName": "Last Name",
          "columnType": "short_text",
          "isRequired": true
        },
        {
          "name": "email",
          "displayName": "Email",
          "columnType": "email",
          "isIndexed": true
        },
        {
          "name": "phone",
          "displayName": "Phone",
          "columnType": "phone"
        },
        {
          "name": "company_name",
          "displayName": "Company",
          "columnType": "short_text",
          "description": "Company name as captured — becomes (or matches) a companies record on conversion."
        },
        {
          "name": "title",
          "displayName": "Job Title",
          "columnType": "short_text"
        },
        {
          "name": "source",
          "displayName": "Source",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "website",
              "referral",
              "outbound",
              "event",
              "advertising",
              "partner",
              "other"
            ]
          }
        },
        {
          "name": "status",
          "displayName": "Status",
          "columnType": "enum",
          "defaultValue": "new",
          "isIndexed": true,
          "constraints": {
            "enumValues": [
              "new",
              "working",
              "qualified",
              "converted",
              "disqualified"
            ]
          },
          "uiOptions": {
            "choiceColors": {
              "new": "#3b82f6",
              "working": "#f59e0b",
              "qualified": "#8b5cf6",
              "converted": "#22c55e",
              "disqualified": "#6b7280"
            }
          }
        },
        {
          "name": "notes",
          "displayName": "Notes",
          "columnType": "long_text"
        },
        {
          "name": "converted_at",
          "displayName": "Converted At",
          "columnType": "datetime",
          "description": "Set by the convert_lead action."
        }
      ]
    },
    {
      "name": "companies",
      "displayName": "Companies",
      "description": "Organizations you sell to.",
      "fields": [
        {
          "name": "name",
          "displayName": "Name",
          "columnType": "short_text",
          "isRequired": true,
          "isIndexed": true
        },
        {
          "name": "domain",
          "displayName": "Domain",
          "columnType": "short_text",
          "isUnique": true,
          "description": "Primary email/website domain, e.g. acme.com."
        },
        {
          "name": "website",
          "displayName": "Website",
          "columnType": "url"
        },
        {
          "name": "industry",
          "displayName": "Industry",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "technology",
              "finance",
              "healthcare",
              "retail",
              "manufacturing",
              "education",
              "real_estate",
              "energy",
              "media",
              "nonprofit",
              "other"
            ]
          }
        },
        {
          "name": "employee_count",
          "displayName": "Employees",
          "columnType": "integer",
          "constraints": {
            "min": 0
          }
        },
        {
          "name": "annual_revenue",
          "displayName": "Annual Revenue",
          "columnType": "currency"
        },
        {
          "name": "city",
          "displayName": "City",
          "columnType": "short_text"
        },
        {
          "name": "country",
          "displayName": "Country",
          "columnType": "short_text"
        },
        {
          "name": "linkedin_url",
          "displayName": "LinkedIn",
          "columnType": "url"
        },
        {
          "name": "description",
          "displayName": "Description",
          "columnType": "long_text"
        }
      ]
    },
    {
      "name": "contacts",
      "displayName": "Contacts",
      "description": "People at the companies you work with.",
      "fields": [
        {
          "name": "first_name",
          "displayName": "First Name",
          "columnType": "short_text",
          "isRequired": true
        },
        {
          "name": "last_name",
          "displayName": "Last Name",
          "columnType": "short_text",
          "isRequired": true
        },
        {
          "name": "email",
          "displayName": "Email",
          "columnType": "email",
          "isUnique": true,
          "isIndexed": true
        },
        {
          "name": "phone",
          "displayName": "Phone",
          "columnType": "phone"
        },
        {
          "name": "title",
          "displayName": "Job Title",
          "columnType": "short_text"
        },
        {
          "name": "lifecycle_stage",
          "displayName": "Lifecycle Stage",
          "columnType": "enum",
          "defaultValue": "lead",
          "constraints": {
            "enumValues": [
              "lead",
              "marketing_qualified",
              "sales_qualified",
              "opportunity",
              "customer",
              "churned"
            ]
          },
          "uiOptions": {
            "choiceColors": {
              "lead": "#3b82f6",
              "marketing_qualified": "#8b5cf6",
              "sales_qualified": "#f59e0b",
              "opportunity": "#f97316",
              "customer": "#22c55e",
              "churned": "#6b7280"
            }
          }
        },
        {
          "name": "lead_source",
          "displayName": "Lead Source",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "website",
              "referral",
              "outbound",
              "event",
              "advertising",
              "partner",
              "other"
            ]
          }
        },
        {
          "name": "do_not_contact",
          "displayName": "Do Not Contact",
          "columnType": "boolean",
          "defaultValue": "false"
        },
        {
          "name": "last_activity_at",
          "displayName": "Last Activity",
          "columnType": "datetime",
          "isIndexed": true,
          "description": "Stamped by the log_activity action."
        },
        {
          "name": "linkedin_url",
          "displayName": "LinkedIn",
          "columnType": "url"
        },
        {
          "name": "notes",
          "displayName": "Notes",
          "columnType": "long_text"
        }
      ]
    },
    {
      "name": "deals",
      "displayName": "Deals",
      "description": "Revenue opportunities moving through the pipeline. Every change is recorded in deal_history.",
      "fields": [
        {
          "name": "title",
          "displayName": "Title",
          "columnType": "short_text",
          "isRequired": true
        },
        {
          "name": "amount",
          "displayName": "Amount",
          "columnType": "currency"
        },
        {
          "name": "stage",
          "displayName": "Stage",
          "columnType": "enum",
          "defaultValue": "prospecting",
          "isIndexed": true,
          "constraints": {
            "enumValues": [
              "prospecting",
              "qualification",
              "proposal",
              "negotiation",
              "closed_won",
              "closed_lost"
            ]
          },
          "uiOptions": {
            "choiceColors": {
              "prospecting": "#3b82f6",
              "qualification": "#8b5cf6",
              "proposal": "#f59e0b",
              "negotiation": "#f97316",
              "closed_won": "#22c55e",
              "closed_lost": "#ef4444"
            }
          }
        },
        {
          "name": "probability",
          "displayName": "Probability",
          "columnType": "percentage",
          "defaultValue": "10",
          "constraints": {
            "min": 0,
            "max": 100
          },
          "description": "Win likelihood in % — set_deal_stage applies per-stage defaults."
        },
        {
          "name": "close_date",
          "displayName": "Expected Close",
          "columnType": "date"
        },
        {
          "name": "closed_at",
          "displayName": "Closed At",
          "columnType": "datetime",
          "description": "Set by set_deal_stage when the deal reaches closed_won/closed_lost."
        },
        {
          "name": "lost_reason",
          "displayName": "Lost Reason",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "price",
              "competitor",
              "timing",
              "no_budget",
              "unresponsive",
              "other"
            ]
          }
        },
        {
          "name": "source",
          "displayName": "Source",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "website",
              "referral",
              "outbound",
              "event",
              "advertising",
              "partner",
              "other"
            ]
          }
        },
        {
          "name": "next_step",
          "displayName": "Next Step",
          "columnType": "short_text"
        },
        {
          "name": "last_activity_at",
          "displayName": "Last Activity",
          "columnType": "datetime",
          "isIndexed": true,
          "description": "Stamped by the log_activity and set_deal_stage actions."
        },
        {
          "name": "description",
          "displayName": "Description",
          "columnType": "long_text"
        }
      ]
    },
    {
      "name": "activities",
      "displayName": "Activities",
      "description": "Calls, emails, meetings, tasks, and notes — linkable to a contact, company, and/or deal.",
      "fields": [
        {
          "name": "subject",
          "displayName": "Subject",
          "columnType": "short_text",
          "isRequired": true
        },
        {
          "name": "type",
          "displayName": "Type",
          "columnType": "enum",
          "defaultValue": "note",
          "constraints": {
            "enumValues": [
              "call",
              "email",
              "meeting",
              "task",
              "note"
            ]
          },
          "uiOptions": {
            "choiceColors": {
              "call": "#3b82f6",
              "email": "#8b5cf6",
              "meeting": "#f59e0b",
              "task": "#f97316",
              "note": "#6b7280"
            }
          }
        },
        {
          "name": "direction",
          "displayName": "Direction",
          "columnType": "enum",
          "constraints": {
            "enumValues": [
              "inbound",
              "outbound"
            ]
          }
        },
        {
          "name": "notes",
          "displayName": "Notes",
          "columnType": "long_text"
        },
        {
          "name": "due_date",
          "displayName": "Due Date",
          "columnType": "datetime",
          "isIndexed": true
        },
        {
          "name": "completed",
          "displayName": "Completed",
          "columnType": "boolean",
          "defaultValue": "false"
        },
        {
          "name": "completed_at",
          "displayName": "Completed At",
          "columnType": "datetime"
        },
        {
          "name": "duration_minutes",
          "displayName": "Duration (min)",
          "columnType": "integer",
          "constraints": {
            "min": 0
          }
        }
      ]
    },
    {
      "name": "tags",
      "displayName": "Tags",
      "description": "Freeform labels attachable to contacts, companies, and deals.",
      "fields": [
        {
          "name": "name",
          "displayName": "Name",
          "columnType": "short_text",
          "isRequired": true,
          "isUnique": true
        },
        {
          "name": "color",
          "displayName": "Color",
          "columnType": "color"
        }
      ]
    },
    {
      "name": "deal_history",
      "displayName": "Deal History",
      "description": "One row per deal change, written by the persist_event subscription on data.deals.updated — powers stage-velocity reporting.",
      "fields": [
        {
          "name": "changed_at",
          "displayName": "Changed At",
          "columnType": "datetime",
          "isIndexed": true
        },
        {
          "name": "diff",
          "displayName": "Diff",
          "columnType": "json",
          "description": "System-field-free field diff: { field: { before, after } }."
        },
        {
          "name": "snapshot",
          "displayName": "Snapshot",
          "columnType": "json",
          "description": "Full after-image of the deal at the time of the change."
        },
        {
          "name": "changed_by",
          "displayName": "Changed By",
          "columnType": "short_text",
          "description": "Actor id (user or API key) that made the change; empty for system writes."
        },
        {
          "name": "event_id",
          "displayName": "Event ID",
          "columnType": "uuid",
          "isUnique": true,
          "isIndexed": true
        }
      ]
    }
  ],
  "relationships": [
    {
      "name": "company",
      "displayName": "Company",
      "type": "many_to_one",
      "sourceObjectName": "contacts",
      "targetObjectName": "companies"
    },
    {
      "name": "company",
      "displayName": "Company",
      "type": "many_to_one",
      "sourceObjectName": "deals",
      "targetObjectName": "companies"
    },
    {
      "name": "primary_contact",
      "displayName": "Primary Contact",
      "type": "many_to_one",
      "sourceObjectName": "deals",
      "targetObjectName": "contacts"
    },
    {
      "name": "contact",
      "displayName": "Contact",
      "type": "many_to_one",
      "sourceObjectName": "activities",
      "targetObjectName": "contacts"
    },
    {
      "name": "company",
      "displayName": "Company",
      "type": "many_to_one",
      "sourceObjectName": "activities",
      "targetObjectName": "companies"
    },
    {
      "name": "deal",
      "displayName": "Deal",
      "type": "many_to_one",
      "sourceObjectName": "activities",
      "targetObjectName": "deals"
    },
    {
      "name": "converted_company",
      "displayName": "Converted Company",
      "type": "many_to_one",
      "sourceObjectName": "leads",
      "targetObjectName": "companies"
    },
    {
      "name": "converted_contact",
      "displayName": "Converted Contact",
      "type": "many_to_one",
      "sourceObjectName": "leads",
      "targetObjectName": "contacts"
    },
    {
      "name": "converted_deal",
      "displayName": "Converted Deal",
      "type": "many_to_one",
      "sourceObjectName": "leads",
      "targetObjectName": "deals"
    },
    {
      "name": "deal",
      "displayName": "Deal",
      "type": "many_to_one",
      "sourceObjectName": "deal_history",
      "targetObjectName": "deals",
      "cascadeDelete": true
    },
    {
      "name": "tags",
      "displayName": "Tags",
      "type": "many_to_many",
      "sourceObjectName": "contacts",
      "targetObjectName": "tags"
    },
    {
      "name": "tags",
      "displayName": "Tags",
      "type": "many_to_many",
      "sourceObjectName": "companies",
      "targetObjectName": "tags"
    },
    {
      "name": "tags",
      "displayName": "Tags",
      "type": "many_to_many",
      "sourceObjectName": "deals",
      "targetObjectName": "tags"
    }
  ],
  "subscriptions": [
    {
      "event": "data.deals.updated",
      "consumer": "crm_deal_history",
      "handler": "persist_event",
      "config": {
        "object": "deal_history",
        "map": {
          "deal_id": "payload.id",
          "diff": "payload.diff",
          "snapshot": "payload.record",
          "changed_at": "event.occurredAt",
          "changed_by": "payload.actorId",
          "event_id": "event.id"
        }
      }
    }
  ],
