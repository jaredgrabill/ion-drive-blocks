{
  "$id": "https://iondrive.dev/schemas/block-manifest.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "default": ""
    },
    "author": {
      "type": "string",
      "maxLength": 255
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^(@[a-z][a-z0-9-]*\\/)?[a-z][a-z0-9_-]*$"
      },
      "default": {}
    },
    "npmDependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "envVars": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63
                },
                "displayName": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 255
                },
                "columnType": {
                  "type": "string",
                  "enum": [
                    "text",
                    "short_text",
                    "long_text",
                    "rich_text",
                    "email",
                    "url",
                    "phone",
                    "slug",
                    "integer",
                    "big_integer",
                    "decimal",
                    "float",
                    "percentage",
                    "currency",
                    "boolean",
                    "date",
                    "datetime",
                    "time",
                    "uuid",
                    "auto_increment",
                    "json",
                    "array_text",
                    "array_integer",
                    "enum",
                    "multi_enum",
                    "rating",
                    "color",
                    "ip_address"
                  ]
                },
                "isRequired": {
                  "type": "boolean"
                },
                "isUnique": {
                  "type": "boolean"
                },
                "isIndexed": {
                  "type": "boolean"
                },
                "defaultValue": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "constraints": {
                  "type": "object",
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    },
                    "pattern": {
                      "type": "string"
                    },
                    "enumValues": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                },
                "sortOrder": {
                  "type": "integer"
                },
                "description": {
                  "type": "string",
                  "maxLength": 2000
                },
                "uiOptions": {
                  "type": "object",
                  "additionalProperties": {}
                }
              },
              "required": [
                "name",
                "displayName",
                "columnType"
              ],
              "additionalProperties": false
            },
            "minItems": 1
          }
        },
        "required": [
          "name",
          "displayName",
          "fields"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "type": {
            "type": "string",
            "enum": [
              "one_to_one",
              "one_to_many",
              "many_to_one",
              "many_to_many"
            ]
          },
          "sourceObjectName": {
            "type": "string",
            "minLength": 1
          },
          "targetObjectName": {
            "type": "string",
            "minLength": 1
          },
          "cascadeDelete": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "displayName",
          "type",
          "sourceObjectName",
          "targetObjectName"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "seed": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "default": {}
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 2000
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "schedule": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ]
          },
          "timezone": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "config": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "required": [
          "name",
          "type"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": {
                  "type": "string"
                },
                "actions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "resource",
                "actions"
              ],
              "additionalProperties": false
            },
            "minItems": 1
          }
        },
        "required": [
          "name",
          "permissions"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "subscriptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "consumer": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "handler": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "perInstance": {
            "type": "boolean"
          },
          "config": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "required": [
          "event",
          "consumer",
          "handler"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "input": {
            "type": "object",
            "additionalProperties": {}
          },
          "rbac": {
            "type": "object",
            "properties": {
              "resource": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "action": {
                "type": "string",
                "enum": [
                  "create",
                  "read",
                  "update",
                  "delete",
                  "manage"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "webhooks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "url": {
            "type": "string",
            "format": "uri",
            "maxLength": 2000
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "minItems": 1,
            "maxItems": 50
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "maxLength": 4000
            },
            "default": {}
          }
        },
        "required": [
          "name",
          "url",
          "topics"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "requires": {
      "type": "object",
      "properties": {
        "core": {
          "type": "string"
        },
        "handlers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "default": []
        },
        "plugins": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "handlers": [],
        "plugins": []
      }
    },
    "code": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "contents": {
            "type": "string",
            "maxLength": 512000
          }
        },
        "required": [
          "path",
          "contents"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "meta": {
      "type": "object",
      "additionalProperties": {},
      "default": {}
    }
  },
  "required": [
    "name",
    "title"
  ],
  "additionalProperties": false
}
